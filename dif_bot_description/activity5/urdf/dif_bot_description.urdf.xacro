<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dif_bot">

  <!-- Propiedades -->
  <xacro:property name="base_length" value="0.4"/>
  <xacro:property name="base_width" value="0.3"/>
  <xacro:property name="base_height" value="0.1"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.02"/>
  <xacro:property name="caster_radius" value="0.03"/>

  <!-- Macros de inercia -->
  <xacro:macro name="inertia_box" params="m lx ly lz">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m/12*(ly*ly+lz*lz)}"
               iyy="${m/12*(lx*lx+lz*lz)}"
               izz="${m/12*(lx*lx+ly*ly)}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_cylinder" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m/12*(3*r*r+l*l)}"
               iyy="${m/12*(3*r*r+l*l)}"
               izz="${m/2*r*r}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_sphere" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${2/5*m*r*r}"
               iyy="${2/5*m*r*r}"
               izz="${2/5*m*r*r}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- Base -->
  <link name="base_link">
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material><color rgba="0.8 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <xacro:inertia_box m="5.0" lx="${base_length}" ly="${base_width}" lz="${base_height}"/>
  </link>

  <!-- Rueda izquierda -->
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material><color rgba="0.2 0.2 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <xacro:inertia_cylinder m="1.0" r="${wheel_radius}" l="${wheel_width}"/>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${base_width/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rueda derecha -->
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material><color rgba="0.2 0.8 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <xacro:inertia_cylinder m="1.0" r="${wheel_radius}" l="${wheel_width}"/>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -${base_width/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Caster -->
  <link name="caster">
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material><color rgba="0.8 0.8 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <xacro:inertia_sphere m="0.5" r="${caster_radius}"/>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="-${base_length/2} 0 -${caster_radius}" rpy="0 0 0"/>
  </joint>

</robot>
